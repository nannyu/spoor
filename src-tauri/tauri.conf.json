{
  "productName": "Spoor",
  "version": "0.1.0",
  "identifier": "com.spoor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "雪泥 · Spoor — Local First",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "Local-first spatial notes and AI thinking canvas",
    "longDescription": "Spoor (雪泥) — canvas notes, personas, research lab. Data stays on your device (IndexedDB).",
    "category": "Productivity",
    "copyright": "Copyright (c) iimorning. PolyForm Noncommercial License 1.0.0.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
